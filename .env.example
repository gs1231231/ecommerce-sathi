# ============================================
# eCommerce Sathi - Environment Variables
# ============================================

# App
NODE_ENV=development
PORT=3001
WEB_PORT=3000
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_sathi
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# JWT Auth
JWT_ACCESS_SECRET=your-access-secret-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Anthropic Claude AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# Shipping - Delhivery
DELHIVERY_API_KEY=your-delhivery-api-key
DELHIVERY_API_URL=https://staging-express.delhivery.com

# Shipping - Shiprocket
SHIPROCKET_EMAIL=your-shiprocket-email
SHIPROCKET_PASSWORD=your-shiprocket-password

# SMS (MSG91)
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=ECSATH

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ecommercesathi.com

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
S3_BUCKET=
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Logging
LOG_LEVEL=debug
